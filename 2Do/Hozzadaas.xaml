<Window x:Class="_2Do.Hozzadaas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2Do"
        mc:Ignorable="d"
        Title="Hozzadaas" Height="200" Width="300">
    <Grid>
        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
            <Label Content="Új feladat hozzáadása" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel Orientation="Vertical">
                    <Label Content="Title:"/>
                    <Label Content="DeadLine:" Margin="0,5,0,0"/>
                    <Label Content="Description:" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Orientation="Vertical">
                    <TextBox Name="TitleTextBox" Width="200" Margin="5"/>
                    <DatePicker Name="DeadLineTextBox" Width="200" Margin="5"/>
                    <TextBox Name="DescriptionTextBox" Width="200" Margin="5"/>
                </StackPanel>
            </StackPanel>
            <Button Content="Feltöltés" Width="150" Margin="0,10,0,0" Click="Button_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
