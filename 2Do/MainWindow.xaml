<Window x:Class="_2Do.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_2Do"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0">
            <MenuItem Header="File">
                <MenuItem Header="_Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem Header="_Mentes" Click="Mentes_Click"/>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Funkciók" Width="200" Grid.Column="0" Margin="10">
                <StackPanel>
                    <Button Content="Új feladat hozzáadása" Margin="5" Click="NewTask_Click"/>
                    <Button Content="Feladat szerkesztése" Margin="5" Click="EditTask_Click"/>
                    <Button Content="Feladat törlése" Margin="5" Click="DeleteTask_Click"/>
                </StackPanel>
            </GroupBox>
            
            <ListView Name="TaskListView" Margin="10" Grid.Column="1">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="150"/>
                        <GridViewColumn Header="Kész-e" DisplayMemberBinding="{Binding IsCompleted}" Width="80"/>
                        <GridViewColumn Header="Deadline" DisplayMemberBinding="{Binding DueDate}" Width="150"/>
                        <GridViewColumn Header="Description" DisplayMemberBinding="{Binding Description}" Width="200"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
     </Grid>
</Window>
